# ==============================================================================
# 名创优品 AI 产品开发智能决策引擎 - 环境变量配置模板
# ==============================================================================
# 使用方法:
#   cp .env.example .env
#   然后填入实际的密钥和配置值
# ==============================================================================

# ------------------------------------------------------------------------------
# 数据库配置 (TimescaleDB / PostgreSQL)
# ------------------------------------------------------------------------------
# PostgreSQL 容器初始化凭据（与 docker-compose.yml 中保持一致）
POSTGRES_USER=miniso
POSTGRES_PASSWORD=miniso
POSTGRES_DB=miniso_ai
DATABASE_URL=postgresql://miniso:miniso@postgres:5432/miniso_ai
# 本地开发时（非 Docker 内部网络）使用:
# DATABASE_URL=postgresql://miniso:miniso@localhost:5432/miniso_ai

# ------------------------------------------------------------------------------
# Redis 配置
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
# 本地开发时使用:
# REDIS_URL=redis://localhost:6379/0

# Celery 配置
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ------------------------------------------------------------------------------
# OpenAI API (GPT-4 + DALL-E 图像生成)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

# ------------------------------------------------------------------------------
# 飞书 (Feishu / Lark) 集成配置
# ------------------------------------------------------------------------------
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token
# 飞书 API 基础地址
FEISHU_API_BASE_URL=https://open.feishu.cn/open-apis

# ------------------------------------------------------------------------------
# Pinecone 向量数据库配置
# ------------------------------------------------------------------------------
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=miniso-ai-engine

# ------------------------------------------------------------------------------
# 服务端口配置
# ------------------------------------------------------------------------------
TRENDPULSE_PORT=8001
IDEAFORGE_PORT=8002
MARKETPROBE_PORT=8003
FRONTEND_PORT=3000

# ------------------------------------------------------------------------------
# 应用配置
# ------------------------------------------------------------------------------
# 运行环境: development / staging / production
APP_ENV=development
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# JWT 密钥（用于 API 鉴权，生产环境务必更换）
JWT_SECRET_KEY=change-this-to-a-secure-random-string
# 时区
TZ=Asia/Shanghai

# ------------------------------------------------------------------------------
# CORS 跨域配置
# ------------------------------------------------------------------------------
# 允许的前端来源（逗号分隔）；生产环境务必替换为具体域名
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ------------------------------------------------------------------------------
# 数据采集配置 (TrendPulse)
# ------------------------------------------------------------------------------
# 各数据源采集间隔（秒）
COLLECTOR_INTERVAL_SECONDS=3600
# Scrapy 并发请求数
SCRAPY_CONCURRENT_REQUESTS=16
# Playwright 浏览器无头模式
PLAYWRIGHT_HEADLESS=true

# ------------------------------------------------------------------------------
# AI 模型配置 (IdeaForge)
# ------------------------------------------------------------------------------
# XGBoost 爆品预测模型参数
XGBOOST_N_ESTIMATORS=200
XGBOOST_MAX_DEPTH=6
XGBOOST_LEARNING_RATE=0.1
# 漏斗过滤分位数 (P70 = 前 30% 通过, 默认 70)
HIT_SCORE_PERCENTILE=70
# LangChain / LangGraph 配置
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langchain-api-key
