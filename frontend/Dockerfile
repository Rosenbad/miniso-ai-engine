# ==============================================================================
# 名创优品 AI 产品开发智能决策引擎 - 前端 Dockerfile
# ==============================================================================
# Next.js 决策工作台（三栏布局）
# ==============================================================================

FROM node:18-alpine

# 设置环境变量
ENV NODE_ENV=development \
    TZ=Asia/Shanghai

# 设置工作目录
WORKDIR /app

# 先复制依赖文件以利用 Docker 缓存层
COPY package*.json ./
RUN npm install

# 复制项目代码
COPY . .

# 暴露端口
EXPOSE 3000

# 开发模式启动
CMD ["npm", "run", "dev"]
