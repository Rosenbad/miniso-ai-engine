# ==============================================================================
# 名创优品 AI 产品开发智能决策引擎 - .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 环境变量 & 密钥
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env

# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
venv/
env/
ENV/
.venv/
.env/

# 测试 & 覆盖率
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.coverage
coverage.xml
*.cover
.hypothesis/

# ------------------------------------------------------------------------------
# Node.js / Next.js
# ------------------------------------------------------------------------------
node_modules/
.next/
out/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ------------------------------------------------------------------------------
# 数据库
# ------------------------------------------------------------------------------
*.sqlite3
*.sql
!migrations/*.sql

# ------------------------------------------------------------------------------
# 数据文件
# ------------------------------------------------------------------------------
backend/data/*
!backend/data/.gitkeep
!backend/data/ip_database.json
!backend/data/generate_mock_skus.py
!backend/data/mock_skus.csv
!backend/data/xgboost_model.json
*.csv
*.xlsx
*.parquet
!backend/data/mock_skus.csv

# ------------------------------------------------------------------------------
# Playwright
# ------------------------------------------------------------------------------
playwright-report/
test-results/

# ------------------------------------------------------------------------------
# 模型文件
# ------------------------------------------------------------------------------
*.pkl
*.joblib
*.h5
*.pt
*.bin
models_cache/

# ------------------------------------------------------------------------------
# IDE & 编辑器
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------
docker-compose.override.yml

# ------------------------------------------------------------------------------
# 日志
# ------------------------------------------------------------------------------
logs/
*.log

# ------------------------------------------------------------------------------
# 操作系统
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
